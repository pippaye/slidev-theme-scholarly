{
  "Slidev Scholarly: Block (Vue)": {
    "prefix": "ss-block",
    "body": [
      "<Block type=\"${1|info,default,success,warning,danger,example|}\" title=\"${2:Block Title}\">",
      "",
      "${3:Block content goes here.}",
      "",
      "</Block>",
      "",
      "$0"
    ],
    "description": "Insert Block component (Vue syntax)"
  },
