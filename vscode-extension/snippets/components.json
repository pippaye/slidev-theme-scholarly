  "Slidev Scholarly: Steps": {
    "prefix": ["scholarly-steps", "ss-steps"],
    "body": [
      "<Steps :steps=\"[",
      "  { title: '${1:Step 1}', description: '${2:Description 1}' },",
      "  { title: '${3:Step 2}', description: '${4:Description 2}' },",
      "  { title: '${5:Step 3}', description: '${6:Description 3}' }",
      "]\" :activeStep=\"${7:1}\" />",
      "",
      "$0"
    ],
    "description": "Insert Steps component"
  },
