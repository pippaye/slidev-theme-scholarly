    "prefix": ["scholarly-columns-md", "ss-columns-md"],
    "body": [
      ":::columns{columns=\"${1|2,3,4|}\" gap=\"${2:2rem}\" ratio=\"${3:1:1}\"}",
      "${4:Column 1 content}",
      "",
      "+++",
      "",
      "${5:Column 2 content}",
      ":::",
      "",
      "$0"
    ],
    "description": "Insert Columns component (Markdown syntax sugar)"
  },
