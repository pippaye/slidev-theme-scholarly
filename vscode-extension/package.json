{
  "name": "slidev-scholarly-snippets",
  "displayName": "Slidev Scholarly Snippets",
  "description": "Quick snippets and templates for Slidev Theme Scholarly",
  "version": "1.3.2",
  "publisher": "jxpeng98",
  "icon": "images/icon-256.png",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Snippets",
    "Other"
  ],
  "keywords": [
    "slidev",
    "slides",
    "presentation",
    "academic",
    "scholarly",
    "markdown",
    "bibtex"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onView:scholarly-layouts",
    "onView:scholarly-components",
    "onView:scholarly-templates",
    "onView:scholarly-themes",
    "onView:scholarly-cli",
    "onView:scholarly-references",
    "onCommand:slidev-scholarly.newPresentation",
    "onCommand:slidev-scholarly.applyThemePreset",
    "onCommand:slidev-scholarly.setColorTheme",
    "onCommand:slidev-scholarly.setFontTheme",
    "onCommand:slidev-scholarly.setColorMode",
    "onCommand:slidev-scholarly.openSidebar",
    "onCommand:slidev-scholarly.cliAction",
    "onCommand:slidev-scholarly.cliMenu",
    "onCommand:slidev-scholarly.toggleDevMode",
    "onCommand:slidev-scholarly.refreshReferences",
    "onCommand:slidev-scholarly.insertInternalAnchor",
    "onCommand:slidev-scholarly.insertAnchorReference",
    "onCommand:slidev-scholarly.preview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "slidev-scholarly",
          "title": "Slidev Scholarly",
          "icon": "images/slidev-icon.svg"
        }
      ]
    },
    "views": {
      "slidev-scholarly": [
        {
          "id": "scholarly-layouts",
          "name": "Layouts",
          "icon": "$(layout)"
        },
        {
          "id": "scholarly-components",
          "name": "Components",
          "icon": "$(symbol-method)"
        },
        {
          "id": "scholarly-templates",
          "name": "Templates",
          "icon": "$(file-code)"
        },
        {
          "id": "scholarly-themes",
          "name": "Themes",
          "icon": "$(paintcan)"
        },
        {
          "id": "scholarly-references",
          "name": "References",
          "icon": "$(book)"
        },
        {
          "id": "scholarly-cli",
          "name": "CLI",
          "icon": "$(terminal)"
        },
        {
          "type": "webview",
          "id": "scholarly-preview",
          "name": "Preview",
          "icon": "$(eye)",
          "visibility": "hidden"
        }
      ]
    },
    "commands": [
      {
        "command": "slidev-scholarly.insertLayout",
        "title": "Insert Layout",
        "icon": "$(add)"
      },
      {
        "command": "slidev-scholarly.insertComponent",
        "title": "Insert Component",
        "icon": "$(add)"
      },
      {
        "command": "slidev-scholarly.newPresentation",
        "title": "New Scholarly Presentation",
        "icon": "$(new-file)"
      },
      {
        "command": "slidev-scholarly.insertCitation",
        "title": "Insert Citation",
        "icon": "$(quote)"
      },
      {
        "command": "slidev-scholarly.insertInternalAnchor",
        "title": "Insert Internal Anchor",
        "icon": "$(symbol-key)"
      },
      {
        "command": "slidev-scholarly.insertAnchorReference",
        "title": "Insert Internal Anchor Reference",
        "icon": "$(link)"
      },
      {
        "command": "slidev-scholarly.insertBibKey",
        "title": "Insert BibTeX Key",
        "icon": "$(add)"
      },
      {
        "command": "slidev-scholarly.insertAnchorKey",
        "title": "Insert Anchor Key",
        "icon": "$(link)"
      },
      {
        "command": "slidev-scholarly.applyThemePreset",
        "title": "Apply Theme Preset",
        "icon": "$(wand)"
      },
      {
        "command": "slidev-scholarly.setColorTheme",
        "title": "Set Color Theme",
        "icon": "$(symbol-color)"
      },
      {
        "command": "slidev-scholarly.setFontTheme",
        "title": "Set Font Theme",
        "icon": "$(text-size)"
      },
      {
        "command": "slidev-scholarly.setColorMode",
        "title": "Set Color Mode",
        "icon": "$(color-mode)"
      },
      {
        "command": "slidev-scholarly.openSidebar",
        "title": "Open Slidev Scholarly Sidebar",
        "icon": "$(layout-sidebar-left)"
      },
      {
        "command": "slidev-scholarly.refreshReferences",
        "title": "Refresh References",
        "icon": "$(refresh)"
      },
      {
        "command": "slidev-scholarly.cliAction",
        "title": "Run Scholarly CLI Action",
        "icon": "$(terminal)"
      },
      {
        "command": "slidev-scholarly.cliMenu",
        "title": "Scholarly CLI Quick Actions",
        "icon": "$(terminal-bash)"
      },
      {
        "command": "slidev-scholarly.toggleDevMode",
        "title": "Slidev Scholarly: Toggle Dev Mode",
        "icon": "$(debug)"
      },
      {
        "command": "slidev-scholarly.preview",
        "title": "Preview",
        "icon": "$(eye)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "slidev-scholarly.refreshReferences",
          "when": "view == scholarly-references",
          "group": "navigation"
        },
        {
          "command": "slidev-scholarly.insertAnchorReference",
          "when": "view == scholarly-references",
          "group": "navigation@2"
        },
        {
          "command": "slidev-scholarly.insertInternalAnchor",
          "when": "view == scholarly-references",
          "group": "navigation@3"
        },
        {
          "command": "slidev-scholarly.applyThemePreset",
          "when": "view == scholarly-themes",
          "group": "navigation"
        },
        {
          "command": "slidev-scholarly.setColorTheme",
          "when": "view == scholarly-themes",
          "group": "navigation"
        },
        {
          "command": "slidev-scholarly.setFontTheme",
          "when": "view == scholarly-themes",
          "group": "navigation"
        },
        {
          "command": "slidev-scholarly.setColorMode",
          "when": "view == scholarly-themes",
          "group": "navigation"
        },
        {
          "command": "slidev-scholarly.cliMenu",
          "when": "view == scholarly-cli",
          "group": "navigation"
        },
        {
          "command": "slidev-scholarly.toggleDevMode",
          "when": "view == scholarly-cli",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "slidev-scholarly.insertLayout",
          "when": "view == scholarly-layouts && viewItem == layoutSnippet",
          "group": "inline@1"
        },
        {
          "command": "slidev-scholarly.preview",
          "when": "view == scholarly-layouts && viewItem == layoutSnippet",
          "group": "inline@2"
        },
        {
          "command": "slidev-scholarly.insertComponent",
          "when": "view == scholarly-components && viewItem == componentSnippet",
          "group": "inline@1"
        },
        {
          "command": "slidev-scholarly.preview",
          "when": "view == scholarly-components && viewItem == componentSnippet",
          "group": "inline@2"
        },
        {
          "command": "slidev-scholarly.preview",
          "when": "view == scholarly-themes && viewItem =~ /^theme/",
          "group": "inline"
        },
        {
          "command": "slidev-scholarly.insertBibKey",
          "when": "view == scholarly-references && viewItem == referenceCitation",
          "group": "inline"
        },
        {
          "command": "slidev-scholarly.insertAnchorKey",
          "when": "view == scholarly-references && viewItem == referenceAnchor",
          "group": "inline"
        }
      ]
    },
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/layouts.vscode.json"
      },
      {
        "language": "markdown",
        "path": "./snippets/components.vscode.json"
      }
    ],
    "configuration": {
      "title": "Slidev Scholarly",
      "properties": {
        "slidevScholarly.devMode.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable extension development mode with performance diagnostics and timing logs."
        },
        "slidevScholarly.devMode.slowThresholdMs": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "description": "Mark operations slower than this threshold (ms) as SLOW in dev mode."
        }
      }
    }
  },
  "scripts": {
    "sync-shared-data": "node ./scripts/sync-shared-data.mjs",
    "sync-previews": "node ./scripts/sync-previews.mjs",
    "sync-snippets": "node ./scripts/sync-snippets.mjs",
    "vscode:prepublish": "npm run sync-previews && npm run sync-snippets && npm run compile",
    "compile": "npm run sync-shared-data && npm run sync-snippets && tsc -p ./",
    "watch": "npm run sync-shared-data && npm run sync-snippets && tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish",
    "publish:pre": "npx @vscode/vsce publish --pre-release"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.x",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "eslint": "^8.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jxpeng98/slidev-theme-scholarly"
  }
}
