{
  "name": "slidev-theme-scholarly",
  "version": "1.3.2",
  "type": "module",
  "description": "A scholarly presentation theme for Slidev with LaTeX Beamer-style styling",
  "author": "Jiaxin Peng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jxpeng98/slidev-theme-scholarly.git"
  },
  "bugs": {
    "url": "https://github.com/jxpeng98/slidev-theme-scholarly/issues"
  },
  "homepage": "https://github.com/jxpeng98/slidev-theme-scholarly#readme",
  "keywords": [
    "slidev-theme",
    "slidev",
    "scholarly",
    "academic",
    "presentation",
    "beamer",
    "latex"
  ],
  "files": [
    "components",
    "cli",
    "layouts",
    "shared",
    "styles",
    "setup",
    "utils",
    "vite.config.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    }
  },
  "bin": {
    "scholarly": "./cli/scholarly.mjs",
    "sch": "./cli/scholarly.mjs",
    "sts": "./cli/scholarly.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "cli": "node cli/scholarly.mjs --help",
    "dev": "node scripts/slidev.mjs dev --open",
    "build": "node scripts/slidev.mjs build",
    "export": "node scripts/slidev.mjs export",
    "screenshot": "node scripts/slidev.mjs export --format png",
    "export:theme-images": "node scripts/export-theme-images.mjs",
    "export:layout-screenshots": "node scripts/export-layout-screenshots.mjs",
    "export:component-screenshots": "node scripts/export-component-screenshots.mjs",
    "export:all-screenshots": "node scripts/export-all-screenshots.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "version:print": "node -p \"require('./package.json').version\"",
    "version:print:vscode": "node -p \"require('./vscode-extension/package.json').version\"",
    "version:sync": "node scripts/sync-version.mjs",
    "bump": "bash scripts/bump-version.sh",
    "bump:vscode": "bash scripts/bump-vscode-version.sh",
    "tag": "git tag -a \"v$(pnpm -s run version:print)\" -m \"v$(pnpm -s run version:print)\"",
    "tag:push": "git push && git push origin \"v$(pnpm -s run version:print)\"",
    "tag:vscode": "git tag -a \"vscode-v$(pnpm -s run version:print:vscode)\" -m \"vscode-v$(pnpm -s run version:print:vscode)\"",
    "tag:push:vscode": "git push && git push origin \"vscode-v$(pnpm -s run version:print:vscode)\"",
    "tag:vscode:pre": "git tag -a \"vscode-pre-v$(pnpm -s run version:print:vscode)\" -m \"vscode-pre-v$(pnpm -s run version:print:vscode)\"",
    "tag:push:vscode:pre": "git push && git push origin \"vscode-pre-v$(pnpm -s run version:print:vscode)\"",
    "release": "pnpm run version:sync && git add -A && git commit -m \"chore: release v$(pnpm -s run version:print)\" && pnpm run tag && pnpm run tag:push",
    "vscode:compile": "cd vscode-extension && pnpm run compile",
    "vscode:watch": "cd vscode-extension && pnpm run watch",
    "vscode:package": "cd vscode-extension && pnpm run package",
    "vscode:release": "pnpm run vscode:package"
  },
  "dependencies": {
    "@jxpeng98/markdown-it-citation": "1.2.1",
    "@slidev/client": "^52.11.3",
    "@slidev/types": "^52.11.3"
  },
  "devDependencies": {
    "@slidev/cli": "^52.11.3",
    "playwright-chromium": "^1.58.0",
    "vite": "^7.3.0",
    "vitepress": "2.0.0-alpha.15"
  },
  "//": "Learn more: https://sli.dev/guide/write-theme.html",
  "slidev": {
    "colorSchema": "both",
    "defaults": {
      "aspectRatio": "4:3",
      "fonts": {
        "sans": "Inter",
        "serif": "Merriweather",
        "mono": "JetBrains Mono"
      }
    },
    "themeConfig": {
      "author": "Your Name",
      "conference": "Your Conference"
    }
  }
}
